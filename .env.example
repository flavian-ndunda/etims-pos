APP_NAME="eTIMS POS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=daily
LOG_LEVEL=debug

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite is the default — zero setup required
DB_CONNECTION=sqlite
# For MySQL, comment the line above and uncomment below:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=etims_pos
# DB_USERNAME=root
# DB_PASSWORD=

# ─── Queue ────────────────────────────────────────────────────────────────────
# Use database so jobs survive power cuts (stored in SQLite)
QUEUE_CONNECTION=database

# ─── Cache & Session ──────────────────────────────────────────────────────────
CACHE_STORE=file
SESSION_DRIVER=file
SESSION_LIFETIME=480

# ─── KRA eTIMS ────────────────────────────────────────────────────────────────
ETIMS_MODE=sandbox
ETIMS_PIN=P000000000X
ETIMS_BRANCH_ID=00
ETIMS_DEVICE_SERIAL=VSCU000001
ETIMS_SECRET=your-etims-secret
ETIMS_SANDBOX_URL=https://etims-api.kra.go.ke/etims-api/sandbox/vscu
ETIMS_PRODUCTION_URL=https://etims-api.kra.go.ke/etims-api/vscu
ETIMS_QUEUE_CONNECTION=database
ETIMS_QUEUE_NAME=etims
ETIMS_MAX_TRIES=5
ETIMS_LOG_CHANNEL=daily
ETIMS_LOG_REQUESTS=true
ETIMS_LOG_RESPONSES=true
ETIMS_WEBHOOK_VERIFY_SIGNATURE=false
ETIMS_WEBHOOK_SECRET=

# ─── M-Pesa Daraja API ────────────────────────────────────────────────────────
# Get from https://developer.safaricom.co.ke
MPESA_SANDBOX=true
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
MPESA_CALLBACK_URL=https://your-url/api/mpesa/callback
MPESA_RESULT_URL=https://your-url/api/mpesa/result
MPESA_TIMEOUT_URL=https://your-url/api/mpesa/timeout
MPESA_INITIATOR_NAME=
MPESA_SECURITY_CREDENTIAL=
MPESA_USE_CALLBACK=false
MPESA_POLLING_INTERVAL=3
MPESA_POLLING_TIMEOUT=120

# ─── POS Business Details ─────────────────────────────────────────────────────
POS_BUSINESS_NAME="Demo Supermarket Ltd"
POS_BUSINESS_ADDRESS="Tom Mboya Street, Nairobi CBD"
POS_BUSINESS_PHONE="+254 712 345 678"
POS_BRANCH_NAME="Nairobi Main Branch"
